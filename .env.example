# --- Wahoo Cloud API (https://developers.wahooligan.com) ---
# Client ID e Secret dell'app approvata sul Developer Portal
WAHOO_CLIENT_ID=
WAHOO_CLIENT_SECRET=
# Deve combaciare ESATTAMENTE con il redirect URI registrato sul portale
WAHOO_REDIRECT_URI=https://wahoo.miodominio.tld/oauth/callback
# Token condiviso per validare i webhook in ingresso su POST /webhook/wahoo.
# Configuralo sul Developer Portal e mettilo identico qui. Genera con:
#   openssl rand -hex 24
WAHOO_WEBHOOK_TOKEN=

# --- AI ---
# Provider per le analisi: "anthropic" (default) o "openai"
#AI_PROVIDER=anthropic
# API key da https://platform.claude.com/ — usata solo lato server
ANTHROPIC_API_KEY=
# Modello per le analisi (opzionale, default claude-sonnet-4-6)
#ANTHROPIC_MODEL=claude-sonnet-4-6
# Se AI_PROVIDER=openai: key da https://platform.openai.com/api-keys
#OPENAI_API_KEY=
#OPENAI_MODEL=gpt-4o-mini

# --- Google Health API (ex Fitbit, opzionale) ---
# Progetto su Google Cloud Console con Health API abilitata, OAuth client "Web".
# Redirect URI da registrare: {APP_BASE_URL}/oauth/google/callback
#GOOGLE_CLIENT_ID=
#GOOGLE_CLIENT_SECRET=

# --- App ---
# Nome mostrato nell'interfaccia (brand, titolo pagine)
#APP_NAME=OpenFit
# Password di accesso all'app (login rapido, indipendente da Wahoo). Se vuota,
# si accede solo via "Accedi con Wahoo".
APP_PASSWORD=
# Chiave per firmare il cookie di sessione. Genera con:
#   openssl rand -hex 32
APP_SECRET_KEY=
# URL pubblico dell'app (dietro reverse proxy). Se inizia con https:// il cookie
# di sessione viene marcato Secure.
APP_BASE_URL=https://fit.miodominio.tld

# --- Varie ---
TZ=Europe/Rome
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Porta host esposta dal compose (la porta interna resta 8080)
#HOST_PORT=8080
# Minuti di margine prima della scadenza per il refresh del token Wahoo
#TOKEN_REFRESH_MARGIN_MIN=10
